        if mode == "Manual (set values)":
            heart_rate = st.slider("Heart Rate (bpm)", 30, 200, 75)
            systolic_bp = st.slider("Systolic BP (mmHg)", 50, 220, 120)
            diastolic_bp = st.slider("Diastolic BP (mmHg)", 30, 130, 80)
